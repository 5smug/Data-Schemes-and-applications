<?xml version="1.0" encoding="UTF-8"?>
<xs:schema xmlns:xs="http://www.w3.org/2001/XMLSchema" elementFormDefault="qualified">
 <!-- 
    ==================================================================
    This is the schema for the individual xml submission file. 
    See 99999999.xml for a valid example instance. 
    Ensure your [student_no].xml is validated against this schema 
    using Oxygen or some other validator.
